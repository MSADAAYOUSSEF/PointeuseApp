<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="300.0" prefWidth="400.0" spacing="25.0" style="-fx-background-color: #ffffff; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pointeuseapp.controller.SettingsDialogController">

    <VBox spacing="5.0">
        <Label text="CONFIGURATION RÉSEAU" textFill="#0b2545" style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-letter-spacing: -0.5;" />
        <Label text="PARAMÈTRES DE CONNEXION AU SERVEUR" textFill="#64748b" style="-fx-font-weight: bold; -fx-font-size: 10px; -fx-letter-spacing: 1.0;" />
    </VBox>

    <Separator style="-fx-background-color: #f1f5f9;" />

    <GridPane hgap="15" vgap="20">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="ADRESSE IP :" textFill="#475569" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: 800; -fx-font-size: 11px; -fx-letter-spacing: 0.5;" />
        <TextField fx:id="ipField" promptText="ex: 192.168.1.15" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-pref-height: 38px; -fx-text-fill: #1e293b; -fx-font-size: 13px;" />

        <Label text="PORT :" textFill="#475569" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: 800; -fx-font-size: 11px; -fx-letter-spacing: 0.5;" />
        <TextField fx:id="portField" promptText="ex: 8080" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-pref-height: 38px; -fx-text-fill: #1e293b; -fx-font-size: 13px;" />
    </GridPane>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button text="Annuler" onAction="#handleCancel" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 18 10 18;" />

        <Button text="ENREGISTRER" onAction="#handleSave" style="-fx-background-color: #0b2545; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 20 10 20;" />
    </HBox>

</VBox>