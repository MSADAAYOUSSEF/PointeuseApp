<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="250.0" prefWidth="350.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pointeuseapp.controller.SettingsDialogController">

    <Label text="Network Configuration" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Label text="Server connection settings" textFill="#7f8c8d" />

    <GridPane hgap="10" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="IP Address :" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <TextField fx:id="ipField" promptText="e.g. 192.168.1.15" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Port :" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
        <TextField fx:id="portField" promptText="e.g. 8080" GridPane.columnIndex="1" GridPane.rowIndex="1" />
    </GridPane>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50;" />
        <Button text="Save Changes" onAction="#handleSave" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>

</VBox>