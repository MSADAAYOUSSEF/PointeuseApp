<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane prefHeight="600.0" prefWidth="500.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pointeuseapp.controller.ViewController">
    <children>

        <VBox alignment="CENTER" maxWidth="420.0" prefHeight="540.0" spacing="0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-border-width: 1;">

            <effect>
                <DropShadow blurType="GAUSSIAN" height="30.0" radius="14.5" width="30.0" offsetY="5.0">
                    <color>
                        <Color opacity="0.06" />
                    </color>
                </DropShadow>
            </effect>

            <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-padding: 20 30 10 30;">

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <FontIcon iconLiteral="fas-clock" iconSize="32" iconColor="#0b2545"/>
                    <VBox alignment="CENTER_LEFT">
                        <Label text="POINTEUSE" textFill="#0b2545" style="-fx-font-weight: 900; -fx-font-size: 22px; -fx-letter-spacing: -0.5;" />
                        <Label text="PORTAIL EMPLOYÉ" textFill="#64748b" style="-fx-font-weight: bold; -fx-font-size: 10px; -fx-letter-spacing: 1.5;" />
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#onSettingsButtonClick" text="Paramètres" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 12 6 12;">
                    <graphic>
                        <FontIcon iconLiteral="fas-cog" iconSize="14" iconColor="#475569"/>
                    </graphic>
                </Button>
            </HBox>

            <Separator style="-fx-background-color: #f1f5f9;" />

            <VBox alignment="CENTER" spacing="25.0" style="-fx-padding: 25 35 35 35;">

                <VBox alignment="CENTER" spacing="15.0">
                    <Label fx:id="dateLabel" text="Mercredi 13 Mai 2026" textFill="#475569" style="-fx-font-size: 15px; -fx-font-weight: 600;" />

                    <VBox alignment="CENTER" spacing="5.0" prefWidth="350.0" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20 15 20 15;">
                        <Label fx:id="actualTimeLabel" text="11:42" textFill="#0b2545" style="-fx-font-size: 58px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', sans-serif;" />

                        <HBox alignment="CENTER" spacing="6.0">
                            <Label text="ARRONDI :" textFill="#94a3b8" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5;" />
                            <Label fx:id="roundedTimeLabel" text="11:45" textFill="#3b82f6" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="12.0" prefWidth="350.0">

                    <Label text="IDENTIFICATION UTILISATEUR" textFill="#475569" style="-fx-font-weight: 800; -fx-font-size: 11px; -fx-letter-spacing: 0.5;">
                        <graphic>
                            <FontIcon iconLiteral="fas-id-badge" iconSize="13" iconColor="#475569"/>
                        </graphic>
                    </Label>

                    <ComboBox fx:id="employeeComboBox" maxWidth="1.7976931348623157E308" promptText="-- Sélectionnez votre profil --" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 14px; -fx-pref-height: 45px; -fx-text-fill: #1e293b; -fx-cursor: hand;" />

                    <HBox alignment="CENTER" spacing="40.0" style="-fx-padding: 10 0 15 0;">
                        <fx:define>
                            <ToggleGroup fx:id="checkTypeGroup"/>
                        </fx:define>
                        <RadioButton fx:id="radioCheckIn" text="Entrée" selected="true" toggleGroup="$checkTypeGroup" textFill="#1e293b" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;" />
                        <RadioButton fx:id="radioCheckOut" text="Sortie" toggleGroup="$checkTypeGroup" textFill="#1e293b" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;" />
                    </HBox>

                    <Button fx:id="checkButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCheckButtonClick" prefHeight="50.0" style="-fx-background-color: #0b2545; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;" text="VALIDER">
                        <graphic>
                            <FontIcon iconLiteral="fas-check" iconSize="16" iconColor="white"/>
                        </graphic>
                        <font>
                            <Font name="System Bold" size="15.0" />
                        </font>
                        <effect>
                            <DropShadow blurType="GAUSSIAN" height="10.0" radius="4.5" width="10.0" offsetY="3.0">
                                <color>
                                    <Color opacity="0.2" red="0.04" green="0.14" blue="0.27" />
                                </color>
                            </DropShadow>
                        </effect>
                    </Button>

                </VBox>

            </VBox>
        </VBox>
    </children>
</StackPane>